# skilly deployment configuration (SKILLY_SPEC.md §13).
# Copy to .env and fill in. NEVER commit .env. Secrets are injected at runtime only.
# ⚠ Replace EVERY placeholder below (change-me… / generate-with… / all-zero GUID) before deploying — none are safe defaults.

# --- Public URL (used by OIDC redirect + install-URL generation) ---
PUBLIC_BASE_URL=https://skilly.example.com

# --- Postgres ---
POSTGRES_USER=skilly
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=skilly
# Least-privilege app role password (web/worker connect as skilly_app)
SKILLY_APP_PASSWORD=change-me-strong-app

# --- Next.js / Auth.js ---
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# --- Microsoft Entra ID (OIDC SSO) ---
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_SECRET=your-entra-app-client-secret

# --- Bootstrap first Platform Admin (Entra group object id) ---
# Members of this group are Platform Admins from first boot (chicken-and-egg fix).
SKILLY_BOOTSTRAP_ADMIN_GROUP=00000000-0000-0000-0000-000000000000

# --- SCIM provisioning (Entra Enterprise App -> worker /scim/v2) ---
# Bearer token Entra presents on every SCIM request. Treat as a secret.
SCIM_BEARER_TOKEN=generate-a-long-random-token

# --- Object storage (MinIO bundled; or point at real S3) ---
MINIO_ROOT_USER=skilly
MINIO_ROOT_PASSWORD=change-me-strong-minio

# --- Tokens ---
ONE_TIME_TOKEN_TTL_SECONDS=300   # one-time install token TTL (configurable, §9)

# --- Content-Security-Policy (web, §22) ---
# enforce (default) | report-only | off:
#   enforce      strict nonce-based CSP (the shipped default even when unset; recommended).
#   report-only  send Content-Security-Policy-Report-Only — NOTHING is blocked, violations POST to
#                /api/csp-report — use to shake out a custom edge/proxy or overrides before enforcing.
#   off          revert to the legacy 'unsafe-inline' script policy (escape hatch).
# Production-only: `next dev` always uses the lenient dev policy regardless of this value.
# CSP_MODE=enforce

# --- Git gateway client IP (worker, §9/§23) ---
# So the worker records the real client IP of an install (shown on /installed) instead of the
# reverse proxy's address. Passed to Express `trust proxy`: a hop count ("1"), "true"/"false",
# a preset ("loopback"), or a comma-separated subnet list. UNSET = don't trust X-Forwarded-For
# (records the socket peer / null). Set to the number of proxies in front of the worker.
# TRUST_PROXY=1

# --- Observability (§14) ---
# If set, GET /metrics on web + worker requires "Authorization: Bearer <token>".
# Leave unset to expose metrics unauthenticated on the internal network.
# METRICS_TOKEN=
# Pointer re-scan / drift-check cadence (worker, leader-only). Default 24h.
# POINTER_REFRESH_INTERVAL_MS=86400000

# --- Notification delivery (all optional; the in-app inbox always works, §12) ---
# Graph email service account (preferred email transport): a platform admin connects a
# Microsoft 365 service mailbox from the Administration page. Requires a SEPARATE Entra
# app registration (not the OIDC app) with delegated Mail.Send + offline_access
# (admin-consented), Assignment required = Yes (assign only the service mailbox user),
# and redirect URI <PUBLIC_BASE_URL>/api/admin/email/callback.
# EMAIL_TOKEN_ENC_KEY=    # openssl rand -base64 32  (must decode to exactly 32 bytes)
# ENTRA_EMAIL_CLIENT_ID=  # client id of the email-only app registration
# ENTRA_EMAIL_CLIENT_SECRET=  # its client secret
# SMTP: the fallback email transport (plain-text) when no Graph account is operational.
# Leave SMTP_HOST unset to disable.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=0            # 1 for implicit TLS (port 465)
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=skilly@example.com
# Outbound webhook: POST a JSON body per notification (Teams/Slack incoming webhook URL).
# NOTIFY_WEBHOOK_URL=
