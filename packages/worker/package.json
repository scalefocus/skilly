{
  "name": "@skilly/worker",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env.local src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.json && find dist -name '*.test.js' | xargs node --test",
    "lint": "echo \"(configure eslint)\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1089.0",
    "@skilly/shared": "workspace:*",
    "adm-zip": "^0.6.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "tar": "^7.5.20"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/express": "^5.0.0",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^6.4.15",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^7.2.1",
    "supertest": "^7.0.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
